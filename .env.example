# ══════════════════════════════════════════════════════════════════════════════
# .env.example — Copy to .env and fill in your values
# ══════════════════════════════════════════════════════════════════════════════

# ── LiveKit Cloud ───────────────────────────────────────────────────────────
# Get from: https://cloud.livekit.io/ → your project → Settings
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=your_livekit_api_secret_here
LIVEKIT_AGENT_NAME=inbound-receptionist

# ── OpenAI (LLM) ────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Sarvam AI (STT + TTS) ───────────────────────────────────────────────────
# Get from: https://app.sarvam.ai/
SARVAM_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Cal.com (Booking) ───────────────────────────────────────────────────────
# Get from: https://app.cal.com/settings/developer/api-keys
CAL_API_KEY=cal_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CAL_EVENT_TYPE_ID=1234567

# ── S3-Compatible Recording Storage ─────────────────────────────────────────
S3_ENDPOINT=https://your-s3-compatible-endpoint
S3_ACCESS_KEY=your_s3_access_key
S3_SECRET_KEY=your_s3_secret_key
S3_BUCKET=call-recordings
S3_REGION=ap-south-1

# ── Fast2SMS Notifications ──────────────────────────────────────────────────
FAST2SMS_API_KEY=your_fast2sms_authorization_key
FAST2SMS_SENDER_ID=FSTSMS
FAST2SMS_ROUTE=q

# ── SIP / VoBiz (optional) ──────────────────────────────────────────────────
VOBIZ_SIP_DOMAIN=your_sip_domain.sip.vobiz.ai
VOBIZ_USERNAME=your_username
VOBIZ_PASSWORD=your_password
VOBIZ_OUTBOUND_NUMBER=+91XXXXXXXXXX

# ── Call Transfer ────────────────────────────────────────────────────────────
# Phone number to transfer calls to (human agent fallback)
DEFAULT_TRANSFER_NUMBER=+91XXXXXXXXXX

# ── PostgreSQL ───────────────────────────────────────────────────────────────
USE_POSTGRES=true
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Optional pool sizing (defaults: min=1, max=10). Tune only if metrics justify.
# POSTGRES_POOL_MIN=1
# POSTGRES_POOL_MAX=10

# ── Dashboard Auth ───────────────────────────────────────────────────────────
# PostgreSQL users/tenants are the only dashboard credential source.
SESSION_SECRET=replace-with-a-long-random-string
# Required in production if you want to query /api/internal/runtime/auth.
INTERNAL_API_TOKEN=replace-with-a-long-random-token

# Optional log level for new backend/ code (defaults to INFO).
# LOG_LEVEL=INFO
